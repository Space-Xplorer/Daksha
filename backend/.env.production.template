# ============================================================================
# Daksha Production Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Flask Configuration
# ----------------------------------------------------------------------------
FLASK_ENV=production
SECRET_KEY=<generate-strong-secret-key-here>
JWT_SECRET_KEY=<generate-strong-jwt-secret-here>
PORT=8000
API_HOST=0.0.0.0

# ----------------------------------------------------------------------------
# CORS Configuration
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ----------------------------------------------------------------------------
# OCR Configuration
# ----------------------------------------------------------------------------
# OCR_MODE: 'mock' for testing, 'production' for real OCR
OCR_MODE=production

# Path to Tesseract executable (required if OCR_MODE=production)
# Windows: C:/Program Files/Tesseract-OCR/tesseract.exe
# Linux: /usr/bin/tesseract
# Mac: /usr/local/bin/tesseract
TESSERACT_PATH=/usr/bin/tesseract

# Minimum confidence threshold for OCR results (0-100)
OCR_CONFIDENCE_THRESHOLD=60

# ----------------------------------------------------------------------------
# LLM Configuration (GROQ)
# ----------------------------------------------------------------------------
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=<your-groq-api-key-here>
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2

# ----------------------------------------------------------------------------
# Model Configuration
# ----------------------------------------------------------------------------
# Directory containing trained ML models
MODELS_DIR=models

# Validate models on startup (recommended for production)
MODEL_VALIDATION_ON_STARTUP=true

# ----------------------------------------------------------------------------
# Database Configuration (Mock)
# ----------------------------------------------------------------------------
# Path to mock DigiLocker database
MOCK_DB_PATH=src/mock_db.json

# Simulated network delay for KYC verification (seconds)
KYC_NETWORK_DELAY=1.5

# ----------------------------------------------------------------------------
# Fraud Detection Configuration
# ----------------------------------------------------------------------------
# Enable/disable fraud detection system
FRAUD_DETECTION_ENABLED=true

# Fraud score threshold for flagging (0-100)
# Scores above this trigger manual review
FRAUD_DETECTION_THRESHOLD=40

# Fraud score threshold for auto-rejection (0-100)
# Scores above this automatically reject the application
FRAUD_AUTO_REJECT_THRESHOLD=70

# Enable/disable individual fraud detection layers
FRAUD_IMAGE_ANALYSIS=true
FRAUD_METADATA_ANALYSIS=true
FRAUD_CONTENT_ANALYSIS=true
FRAUD_CROSS_DOC_ANALYSIS=true

# LLM model for fraud detection content analysis
FRAUD_LLM_MODEL=llama-3.3-70b-versatile
FRAUD_LLM_TEMPERATURE=0.1

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=daksha_api.log

# Log to console in addition to file
LOG_TO_CONSOLE=true

# Log format: 'json' for structured logging, 'text' for human-readable
LOG_FORMAT=json

# ----------------------------------------------------------------------------
# Monitoring & Metrics
# ----------------------------------------------------------------------------
# Enable Prometheus metrics endpoint
ENABLE_METRICS=true

# Port for metrics endpoint
METRICS_PORT=9090

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Maximum requests per minute per client IP
RATE_LIMIT_PER_MINUTE=60

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
# Enable HTTPS redirect (set to true in production)
FORCE_HTTPS=false

# Session timeout (minutes)
SESSION_TIMEOUT=30

# Maximum file upload size (MB)
MAX_UPLOAD_SIZE=10

# ----------------------------------------------------------------------------
# Compliance
# ----------------------------------------------------------------------------
# Enable compliance checking
COMPLIANCE_ENABLED=true

# Path to regulatory rules directory
RULES_DIR=src/rules

# ----------------------------------------------------------------------------
# Performance
# ----------------------------------------------------------------------------
# Enable async processing for LLM calls
ASYNC_LLM_ENABLED=true

# Maximum concurrent LLM requests
MAX_CONCURRENT_LLM=10

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# ----------------------------------------------------------------------------
# Development/Testing Overrides
# ----------------------------------------------------------------------------
# Bypass compliance checks (NEVER use in production!)
BYPASS_COMPLIANCE=false

# Use mock predictions (NEVER use in production!)
USE_MOCK_PREDICTIONS=false

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
# 1. Generate strong secrets using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. Install Tesseract: https://github.com/tesseract-ocr/tesseract
# 3. Get GROQ API key: https://console.groq.com/
# 4. Ensure all .pkl model files are in MODELS_DIR
# 5. Review and update CORS_ORIGINS for your domain
# 6. Set FRAUD_DETECTION_ENABLED=true for production
# 7. Set LOG_FORMAT=json for production monitoring
# 8. Never commit .env file to version control!
